# ── Database (Turso) ────────────────────────────────────────────
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=

# ── Backend ─────────────────────────────────────────────────────
APP_SECRET=                       # JWT signing secret for auth tokens (required in production)
READ_TOKEN_SECRET=                # Separate secret for read session tokens (optional, falls back to APP_SECRET)

# ── Server ──────────────────────────────────────────────────────
PORT=3000